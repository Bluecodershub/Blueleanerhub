# =============================================================================
# BlueLearnerHub AI Services - Environment Variables
# =============================================================================
# Copy to .env and fill in values before running.

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
PORT=8000
NODE_ENV=development

# Shared secret used by backend-to-worker calls.
# Set the same value in Backend/.env when INTERNAL_SERVICE_SECRET is enabled.
INTERNAL_SERVICE_SECRET=

# -----------------------------------------------------------------------------
# Inbuilt Model Providers
# -----------------------------------------------------------------------------
# BlueLearner is the optional Python local-model worker.
# Run it separately on port 8002 before enabling this flag.
BLUELEARNER_ENABLED=false
BLUELEARNER_URL=http://localhost:8002

# Ollama is the general local LLM fallback.
# Leave OLLAMA_URL blank if you do not want the gateway to try Ollama.
OLLAMA_URL=http://localhost:11434
LOCAL_LLM_MODEL=llama3

# -----------------------------------------------------------------------------
# Legacy Hosted AI
# -----------------------------------------------------------------------------
# Gemini is intentionally disabled in the provider service.
# Keep this blank unless a future implementation explicitly re-enables it.
GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# Optional Python ML Worker
# -----------------------------------------------------------------------------
PYTHON_WORKER_ENABLED=true
PYTHON_WORKER_TIMEOUT=60000

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:5000
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000
