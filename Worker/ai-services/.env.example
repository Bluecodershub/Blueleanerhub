# =============================================================================
# BlueLearnerHub AI Services — Environment Variables
# =============================================================================
# Copy to .env and fill in values before running.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8001
NODE_ENV=development

# ── Gemini AI  ← REQUIRED ─────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
# Get from: https://aistudio.google.com/app/apikey

GEMINI_MODEL=gemini-1.5-flash
# Options: gemini-1.5-flash (fast) | gemini-1.5-pro (smarter, slower)

GEMINI_TEMPERATURE=0.7
GEMINI_MAX_TOKENS=2048

# ── Ollama (optional local LLM) ───────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
LOCAL_LLM_MODEL=llama3

# ── Python ML Worker (optional advanced ML features) ──────────────────────────
PYTHON_WORKER_ENABLED=true
PYTHON_WORKER_TIMEOUT=60000

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5000
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000
