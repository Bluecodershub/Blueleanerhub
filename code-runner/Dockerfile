# --- build stage -------------------------------------------------------------
FROM golang:1.22-alpine AS build
WORKDIR /src
COPY go.mod ./
# go.sum is generated by `go mod tidy`; copy if present.
COPY go.su[m] ./
RUN go mod download || true
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /out/code-runner .

# --- runtime stage -----------------------------------------------------------
# NOTE: this service shells out to the `docker` CLI to sandbox each run, so the
# container needs access to a Docker daemon (mount /var/run/docker.sock) and the
# docker client installed. Running execution inside a container that controls the
# host Docker socket is powerful — restrict this service to a dedicated host.
FROM alpine:3.20
RUN apk add --no-cache docker-cli ca-certificates
WORKDIR /app
COPY --from=build /out/code-runner /app/code-runner
EXPOSE 8090
USER root
ENTRYPOINT ["/app/code-runner"]
