# =============================================================================
# Bluelearnerhub Code Runner (Go) — Environment Variables
# =============================================================================
# Copy to .env (or set these in your deployment). Never commit real secrets.

PORT=8090

# --- MongoDB (optional but recommended) --------------------------------------
# Submissions are persisted to the "code_submissions" collection.
# Leave MONGODB_URI empty to run without persistence (a warning is logged).
MONGODB_URI=mongodb://localhost:27017/bluelearnerhub
MONGODB_DB=bluelearnerhub

# --- Execution safety --------------------------------------------------------
# OFF by default. Only set true on a host with Docker that is dedicated to
# sandboxed execution. The runner refuses to run code unless this is true AND
# the Docker CLI is available.
EXECUTION_ENABLED=false

RUN_TIMEOUT_SECONDS=10
MEMORY_LIMIT=128m
CPU_LIMIT=0.5
PIDS_LIMIT=128
MAX_CODE_BYTES=65536
MAX_OUTPUT_KB=64

# --- Auth between backend and runner -----------------------------------------
# Shared secret. When set, callers must send header `X-Runner-Key: <value>`.
# Must match CODE_RUNNER_API_KEY in the Node backend's .env.
RUNNER_API_KEY=
