{
    "compilerOptions":  {
                            "target":  "ES2020",
                            "module":  "commonjs",
                            "moduleResolution": "node",
                            "typeRoots": ["../node_modules/@types", "./node_modules/@types"],
                            "lib":  [
                                        "ES2020",
                                        "DOM"
                                    ],
                            "outDir":  "./dist",
                            "rootDir":  "./src",
"skipLibCheck": true,
                            "strict":  true,
                            "noUnusedLocals":  false,
                            "noUnusedParameters":  false,
                            "noImplicitReturns":  false,
                            "noImplicitAny": false,
                            "noFallthroughCasesInSwitch":  true,
                            "baseUrl":  ".",
                            "paths":  {
                                          "@/*":  [
                                                      "src/*"
                                                  ],
                                          "@/controllers/*":  [
                                                                  "src/controllers/*"
                                                              ],
                                          "@/routes/*":  [
                                                             "src/routes/*"
                                                         ],
                                          "@/middleware/*":  [
                                                                 "src/middleware/*"
                                                             ],
                                          "@/models/*":  [
                                                             "src/models/*"
                                                         ],
                                          "@/services/*":  [
                                                               "src/services/*"
                                                           ],
                                          "@/utils/*":  [
                                                            "src/utils/*"
                                                        ],
                                          "@/config/*":  [
                                                             "src/config/*"
                                                         ],
                                          "@/types/*":  [
                                                            "src/types/*"
                                                        ],
                                          "@bluelearnerhub/shared": ["../packages/shared/src"],
                                          "@bluelearnerhub/shared/*": ["../packages/shared/src/*"]
                                      },
                            "experimentalDecorators":  true,
                            "emitDecoratorMetadata":  true,
                            "esModuleInterop": true,
                            "allowSyntheticDefaultImports": true
                        },
    "include":  [
                    "src/**/*"
                ],
"exclude": [
                    "node_modules",
                    "dist",
                    "tests",
                    "src/**/*.secure.ts",
                    "src/**/*.updated.ts"
                ]
}
