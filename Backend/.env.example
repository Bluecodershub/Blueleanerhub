# =============================================================================
# BlueLearnerHub Backend — Environment Variables
# =============================================================================
# Copy this file to .env and fill in all REQUIRED values before starting.
# Never commit .env to version control.
#
# Sections:
#   1. Server
#   2. Database
#   3. Redis (optional)
#   4. Authentication (JWT + Cookies)  ← REQUIRED
#   5. CORS & URLs                     ← REQUIRED in production
#   6. Email
#   7. AI Services
#   8. OAuth (optional)
#   9. Stripe Payments (optional)
#  10. Code Execution / Judge0 (optional)
#  11. AWS S3 (optional)
#  12. Rate Limiting & Security
#  13. Logging
# =============================================================================


# -----------------------------------------------------------------------------
# 1. SERVER
# -----------------------------------------------------------------------------

NODE_ENV=development
# Options: development | production | test

PORT=5000
# Port the Express server listens on

HOST=0.0.0.0
# Bind address — 0.0.0.0 binds all interfaces (required on Render/Railway)

TRUST_PROXY=true
# Set true when deployed behind a reverse proxy (Render, Railway, Heroku, AWS ALB)
# Required for correct IP detection in rate limiting and logging


# -----------------------------------------------------------------------------
# 2. DATABASE  ← REQUIRED
# -----------------------------------------------------------------------------
# Primary runtime database is MongoDB.
# Use MONGODB_URL (preferred) OR the individual DB_* variables below.

MONGODB_URL=mongodb://localhost:27017/bluelearnerhub
# Full MongoDB connection string. Takes priority over all DB_* variables below.
# Atlas format: mongodb+srv://USER:PASSWORD@cluster.mongodb.net/bluelearnerhub

# Individual MongoDB variables (only used when MONGODB_URL is NOT set)
DB_HOST=localhost
DB_PORT=27017
DB_NAME=bluelearnerhub
DB_USER=
DB_PASSWORD=your_db_password_here

# Optional legacy SQL compatibility database.
# Only needed if you still run the PostgreSQL migration set for legacy features.
DATABASE_URL=
RUN_SQL_MIGRATIONS=false

# Mongo connection tuning (optional)
DB_MAX_CONNECTIONS=20
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=2000


# -----------------------------------------------------------------------------
# 3. REDIS (optional — falls back to in-memory if not set)
# -----------------------------------------------------------------------------
# Redis is used for session storage and caching.
# If not set, the app uses in-memory storage (not suitable for multi-instance).

REDIS_URL=redis://localhost:6379
# Full Redis URL. Takes priority over individual REDIS_* variables.
# Upstash format: rediss://:TOKEN@HOST:PORT

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0


# -----------------------------------------------------------------------------
# 4. AUTHENTICATION  ← ALL REQUIRED (>=32 chars, no placeholder text)
# -----------------------------------------------------------------------------
# Generate strong secrets with: openssl rand -hex 32
# NEVER use the placeholder values below in production.

JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX_openssl_rand_hex_32
# Signs access tokens. Must be >=32 chars. Rotate if compromised.
# Example generation: openssl rand -hex 32

JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_CHAR_RANDOM_HEX_openssl_rand_hex_32
# Signs refresh tokens. Must differ from JWT_SECRET. Must be >=32 chars.

JWT_EXPIRES_IN=7d
# Access token lifetime. Format: Xd (days), Xh (hours), Xm (minutes)

JWT_REFRESH_EXPIRES_IN=30d
# Refresh token lifetime.

SESSION_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX_FOR_SESSIONS_openssl_rand_hex_32
# Signs Express session cookies. Must be >=32 chars.

COOKIE_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX_FOR_COOKIES_openssl_rand_hex_32
# Signs HttpOnly auth cookies. Must be >=32 chars.


# -----------------------------------------------------------------------------
# 5. CORS & URLS  ← REQUIRED in production
# -----------------------------------------------------------------------------

FRONTEND_URL=http://localhost:3000
# Your deployed frontend URL. Used for:
#   - CORS allowed origins
#   - Cookie domain/sameSite settings
#   - Password-reset email links
# Production example: https://bluelearnerhub.com

BACKEND_URL=http://localhost:5000
# Your deployed backend URL. Used for OAuth callback URL construction.
# Production example: https://api.bluelearnerhub.com

CORS_ORIGINS=http://localhost:3000,http://localhost:5000
# Comma-separated list of allowed CORS origins.
# In production, include all frontend domains:
# Example: https://bluelearnerhub.com,https://www.bluelearnerhub.com


# -----------------------------------------------------------------------------
# 6. EMAIL
# -----------------------------------------------------------------------------
# Set EITHER SENDGRID_API_KEY or RESEND_API_KEY to enable email delivery.
# If neither is set, emails are logged to console (development only).

EMAIL_FROM=noreply@bluelearnerhub.com
# Sender address for all outgoing email (must match verified domain).

SENDGRID_API_KEY=
# SendGrid API key (starts with SG.). Takes priority over Resend.
# Get from: https://app.sendgrid.com/settings/api_keys

RESEND_API_KEY=
# Resend API key (starts with re_). Used if SENDGRID_API_KEY is not set.
# Get from: https://resend.com/api-keys


# -----------------------------------------------------------------------------
# 7. AI SERVICES
# -----------------------------------------------------------------------------

AI_SERVICE_URL=http://localhost:8000
# URL of the Node AI gateway in Worker/ai-services.
# On Render (internal): http://ai-service:8000
# On Render (public):   https://your-ai-service.onrender.com

AI_PROVIDER=local
# AI provider for quiz generation and notebook AI.
# Options: local
# Hosted Gemini is disabled in the current inbuilt-model stack.

GEMINI_API_KEY=
# Legacy only. Leave blank unless hosted Gemini support is explicitly re-enabled.

INTERNAL_SERVICE_SECRET=
# Optional shared secret sent to AI services for backend-to-worker calls.

NOTEBOOK_AI_TIMEOUT_MS=20000
# Milliseconds to wait for notebook AI responses before timeout.

ENABLE_DAILY_QUIZ_CRON=true
# Set false to disable the scheduled daily quiz generator.

DAILY_QUIZ_WARMUP_ON_START=false
# Set true only when the AI service is guaranteed to be online at backend startup.


# -----------------------------------------------------------------------------
# 8. OAUTH (optional — leave blank to disable OAuth login)
# -----------------------------------------------------------------------------

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# GitHub OAuth app credentials.
# Create at: https://github.com/settings/developers
# Callback URL: ${BACKEND_URL}/api/auth/oauth/github/callback

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Google OAuth app credentials.
# Create at: https://console.cloud.google.com/apis/credentials
# Callback URL: ${BACKEND_URL}/api/auth/oauth/google/callback

GOOGLE_CALLBACK_URL=
# Optional override for Google OAuth callback URL.
# Leave blank to auto-construct from BACKEND_URL.


# -----------------------------------------------------------------------------
# 9. STRIPE PAYMENTS (optional — leave blank to disable payment features)
# -----------------------------------------------------------------------------

STRIPE_SECRET_KEY=
# Stripe secret key. Starts with sk_live_ (production) or sk_test_ (testing).
# Get from: https://dashboard.stripe.com/apikeys

STRIPE_WEBHOOK_SECRET=
# Stripe webhook signing secret. Starts with whsec_.
# Get from: https://dashboard.stripe.com/webhooks
# Required to verify webhook payloads from Stripe.

STRIPE_PRICE_EXPLORER=
# Stripe Price ID for the Explorer subscription tier (price_xxx).

STRIPE_PRICE_INNOVATOR=
# Stripe Price ID for the Innovator subscription tier (price_xxx).

STRIPE_PRICE_ENTERPRISE=
# Stripe Price ID for the Enterprise subscription tier (price_xxx).


# -----------------------------------------------------------------------------
# 10. CODE EXECUTION / JUDGE0 (optional)
# -----------------------------------------------------------------------------

JUDGE0_API_KEY=
# Required only when JUDGE0_API_URL uses RapidAPI.
# Leave blank when using a self-hosted Judge0 instance.

JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com
# Judge0 API endpoint. For production scale, prefer a self-hosted Judge0 URL.


# -----------------------------------------------------------------------------
# 11. AWS S3 (optional — for file storage)
# -----------------------------------------------------------------------------

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=
# Leave all blank to use local disk storage (UPLOAD_DIR).
# Required only if you want cloud file storage.


# -----------------------------------------------------------------------------
# 12. RATE LIMITING, UPLOAD & SECURITY
# -----------------------------------------------------------------------------

RATE_LIMIT_WINDOW_MS=900000
# Rate limit window in milliseconds (default: 15 minutes = 900000).

RATE_LIMIT_MAX_REQUESTS=100
# Max requests per IP per window for general API routes.

MAX_FILE_SIZE=10485760
# Maximum upload size in bytes (default: 10MB = 10485760).

UPLOAD_DIR=./uploads
# Local directory for file uploads (used when S3 is not configured).

BCRYPT_ROUNDS=12
# bcrypt password hashing rounds (10=fast/weak, 14=slow/strong, 12=balanced).

MAX_LOGIN_ATTEMPTS=5
# Failed login attempts before temporary account lockout.

LOCKOUT_DURATION=900000
# Account lockout duration in milliseconds (default: 15 minutes).


# -----------------------------------------------------------------------------
# 13. LOGGING
# -----------------------------------------------------------------------------

LOG_LEVEL=info
# Winston log level. Options: error | warn | info | http | debug
# Use 'debug' locally, 'info' or 'warn' in production.
