# =============================================================================
# BlueLearnerHub Backend — Production Environment Variables
# =============================================================================
# Copy this file to .env.production and fill in all values before deploying.
# NEVER commit .env.production to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# 1. SERVER (Required)
# -----------------------------------------------------------------------------

NODE_ENV=production
PORT=5000
HOST=0.0.0.0
TRUST_PROXY=true


# -----------------------------------------------------------------------------
# 2. DATABASE (Required)
# -----------------------------------------------------------------------------

DATABASE_URL=postgresql://user:password@host:5432/database


# -----------------------------------------------------------------------------
# 3. REDIS (Optional)
# -----------------------------------------------------------------------------

REDIS_URL=redis://:password@host:6379


# -----------------------------------------------------------------------------
# 4. AUTHENTICATION (Required - generate with: openssl rand -hex 32)
# -----------------------------------------------------------------------------

JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_CHAR_RANDOM_HEX
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d
SESSION_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX
COOKIE_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX


# -----------------------------------------------------------------------------
# 5. CORS & URLS (Required)
# -----------------------------------------------------------------------------

FRONTEND_URL=https://your-domain.com
BACKEND_URL=https://api.your-domain.com
CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com


# -----------------------------------------------------------------------------
# 6. EMAIL (Optional)
# -----------------------------------------------------------------------------

EMAIL_FROM=noreply@your-domain.com
SENDGRID_API_KEY=
RESEND_API_KEY=


# -----------------------------------------------------------------------------
# 7. AI SERVICES (Optional)
# -----------------------------------------------------------------------------

AI_SERVICE_URL=http://ai-services:8000
AI_PROVIDER=gemini
GEMINI_API_KEY=


# -----------------------------------------------------------------------------
# 8. OAUTH (Optional)
# -----------------------------------------------------------------------------

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# -----------------------------------------------------------------------------
# 9. STRIPE PAYMENTS (Optional)
# -----------------------------------------------------------------------------

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=


# -----------------------------------------------------------------------------
# 10. CODE EXECUTION (Optional)
# -----------------------------------------------------------------------------

JUDGE0_API_KEY=


# -----------------------------------------------------------------------------
# 11. AWS S3 (Optional)
# -----------------------------------------------------------------------------

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=


# -----------------------------------------------------------------------------
# 12. SENTRY (Optional - for error tracking)
# -----------------------------------------------------------------------------

SENTRY_DSN=


# -----------------------------------------------------------------------------
# 13. LOGGING
# -----------------------------------------------------------------------------

LOG_LEVEL=info