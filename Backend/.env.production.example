# =============================================================================
# BlueLearnerHub Backend — Production Environment Variables
# =============================================================================
# Copy this file to .env.production and fill in all values before deploying.
# NEVER commit .env.production to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# 1. SERVER (Required)
# -----------------------------------------------------------------------------

NODE_ENV=production
PORT=5000
HOST=0.0.0.0
TRUST_PROXY=true


# -----------------------------------------------------------------------------
# 2. DATABASE (Required)
# -----------------------------------------------------------------------------

# Primary database — MongoDB Atlas (required in production)
# Get this from Atlas Dashboard → Connect → Drivers → copy the connection string
MONGODB_URL=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/bluelearnerhub?retryWrites=true&w=majority

# Optional component-level overrides (if not using MONGODB_URL directly)
# DB_HOST=
# DB_PORT=27017
# DB_NAME=bluelearnerhub
# DB_USER=
# DB_PASSWORD=


# -----------------------------------------------------------------------------
# 3. REDIS (Optional)
# -----------------------------------------------------------------------------

REDIS_URL=redis://:password@host:6379


# -----------------------------------------------------------------------------
# 4. AUTHENTICATION (Required - generate with: openssl rand -hex 32)
# -----------------------------------------------------------------------------

JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_CHAR_RANDOM_HEX
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d
SESSION_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX
COOKIE_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX


# -----------------------------------------------------------------------------
# 5. CORS & URLS (Required)
# -----------------------------------------------------------------------------

# The deployed Vercel frontend URL — used for CORS, cookies, email links
FRONTEND_URL=https://bluelearnerhub.vercel.app

# This service's own public URL — used for OAuth callback URLs
BACKEND_URL=https://bluelearnerhub-backend.onrender.com

# Comma-separated list of origins allowed by CORS
# Include both the apex domain and www, plus any preview URLs during staging
CORS_ORIGINS=https://bluelearnerhub.vercel.app,https://bluelearnerhub.com,https://www.bluelearnerhub.com


# -----------------------------------------------------------------------------
# 6. EMAIL (Optional)
# -----------------------------------------------------------------------------

EMAIL_FROM=noreply@your-domain.com
SENDGRID_API_KEY=
RESEND_API_KEY=


# -----------------------------------------------------------------------------
# 7. AI SERVICES (Optional)
# -----------------------------------------------------------------------------

AI_SERVICE_URL=http://ai-services:8000
AI_PROVIDER=local
GEMINI_API_KEY=
INTERNAL_SERVICE_SECRET=


# -----------------------------------------------------------------------------
# 8. OAUTH (Optional)
# -----------------------------------------------------------------------------

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# -----------------------------------------------------------------------------
# 9. STRIPE PAYMENTS (Optional)
# -----------------------------------------------------------------------------

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=


# -----------------------------------------------------------------------------
# 10. CODE EXECUTION (Optional)
# -----------------------------------------------------------------------------

JUDGE0_API_KEY=


# -----------------------------------------------------------------------------
# 11. AWS S3 (Optional)
# -----------------------------------------------------------------------------

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=


# -----------------------------------------------------------------------------
# 12. SENTRY (Optional - for error tracking)
# -----------------------------------------------------------------------------

SENTRY_DSN=


# -----------------------------------------------------------------------------
# 13. LOGGING
# -----------------------------------------------------------------------------

LOG_LEVEL=info
