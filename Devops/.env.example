# BluelearnerHub Development Environment
# Copy this file to .env and fill in the values
#
# Generate secrets using: openssl rand -hex <bytes>
#   32 bytes = 64 hex chars (recommended for secrets)
#   16 bytes = 32 hex chars (minimum for passwords)

# ── Database ──────────────────────────────────────────────────────────────────
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=<generate-with-openssl-rand-hex-32>

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=<generate-with-openssl-rand-hex-32>

# ── Internal Service Auth ─────────────────────────────────────────────────────
# Shared secret between backend and AI worker. Must match on both services.
INTERNAL_SERVICE_SECRET=<generate-with-openssl-rand-hex-32>

# ── JWT & Session Secrets (64+ chars each) ────────────────────────────────────
JWT_SECRET=<generate-with-openssl-rand-hex-64>
JWT_REFRESH_SECRET=<generate-with-openssl-rand-hex-64>
SESSION_SECRET=<generate-with-openssl-rand-hex-64>
COOKIE_SECRET=<generate-with-openssl-rand-hex-64>

# ── External Services (optional for development) ──────────────────────────────
GEMINI_API_KEY=
JUDGE0_API_KEY=
# Required only when JUDGE0_API_URL uses RapidAPI.
JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com
# For production-scale hackathons, prefer a self-hosted Judge0 endpoint.
SENDGRID_API_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# ── OAuth (optional) ─────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Feature Flags ─────────────────────────────────────────────────────────────
ENABLE_AI_COMPANION=true
ENABLE_ANALYTICS=false
ENABLE_DAILY_QUIZ_CRON=true
DAILY_QUIZ_WARMUP_ON_START=false

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Network (optional) ────────────────────────────────────────────────────────
DOCKER_NETWORK_SUBNET=172.20.0.0/16
